<%- include('../partials/header', { titulo: 'Configuración', usuario: usuario, seccion: 'admin_config' }) %>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-gear me-2"></i>Configuración del Negocio</div>
            <div class="card-body">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger py-2 small"><%= error %></div>
                <% } %>
                <form action="/kiosco/admin/config" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Nombre del Comercio</label>
                        <input type="text" class="form-control form-control-sm" name="cfg_nombre_comercio" value="<%= config.nombre_comercio || '' %>" maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Dirección</label>
                        <input type="text" class="form-control form-control-sm" name="cfg_direccion" value="<%= config.direccion || '' %>" maxlength="200">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Teléfono</label>
                        <input type="text" class="form-control form-control-sm" name="cfg_telefono" value="<%= config.telefono || '' %>" maxlength="20">
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-medium">Logo</label>
                        <input type="file" class="form-control form-control-sm" name="cfg_logo" accept=".png,.jpg,.jpeg,.gif">
                        <% if (config.logo) { %>
                            <div class="mt-2">
                                <img src="/uploads/<%= config.logo.replace(/\\/g, '/').split('uploads/')[1] || config.logo %>" class="img-thumbnail" style="max-height:80px;">
                            </div>
                        <% } %>
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-save me-1"></i>Guardar Configuración</button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
