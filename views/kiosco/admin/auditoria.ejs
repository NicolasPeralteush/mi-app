<%- include('../partials/header', { titulo: 'Auditoría', usuario: usuario, seccion: 'admin_auditoria' }) %>

<div class="card">
    <div class="card-header"><i class="bi bi-journal-text me-2"></i>Registro de Auditoría <small class="text-muted">(<%= total %> registros)</small></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fecha</th>
                        <th>Usuario</th>
                        <th>Acción</th>
                        <th>Detalle</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (registros.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-4 d-block mb-1"></i><small>Sin registros</small></td></tr>
                    <% } else { %>
                        <% registros.forEach(function(r) { %>
                            <tr>
                                <td><small><%= r.id %></small></td>
                                <td><small><%= new Date(r.created_at).toLocaleString('es-ES') %></small></td>
                                <td><small><%= r.usuario_nombre || r.usuario || '-' %></small></td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary"><%= r.accion %></span></td>
                                <td><small class="text-muted"><%= r.detalle || '-' %></small></td>
                                <td><small><%= r.ip || '-' %></small></td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (pages > 1) { %>
            <nav class="mt-3">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= page - 1 %>"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    <% for (let i = 1; i <= pages; i++) { %>
                        <li class="page-item <%= i === page ? 'active' : '' %>">
                            <a class="page-link" href="?page=<%= i %>"><i class="bi bi-<%= i %>"></i></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= page >= pages ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= page + 1 %>"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
