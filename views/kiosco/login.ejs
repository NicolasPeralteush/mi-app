<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión - Kiosco</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; }
        .card-login { border: none; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }
        .btn-login { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 50px; padding: 12px; font-weight: 600; }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(102,126,234,0.4); }
        .form-control { border-radius: 50px; padding: 12px 20px; }
        .input-group-text { border-radius: 50px 0 0 50px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card card-login p-4">
                    <div class="card-body text-center">
                        <i class="bi bi-shop text-primary mb-3" style="font-size:3rem;"></i>
                        <h4 class="fw-bold mb-1">Módulo Kiosco</h4>
                        <p class="text-muted small mb-4">Ingrese sus credenciales</p>

                        <% if (locals.error) { %>
                            <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-circle me-1"></i><%= error %></div>
                        <% } %>

                        <form action="/kiosco/login" method="POST">
                            <div class="mb-3">
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                                    <input type="text" class="form-control" name="usuario" placeholder="Usuario" required autofocus>
                                </div>
                            </div>
                            <div class="mb-4">
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                                    <input type="password" class="form-control" name="password" placeholder="Contraseña" required>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-login text-white w-100"><i class="bi bi-box-arrow-in-right me-2"></i>Ingresar</button>
                        </form>
                    </div>
                </div>
                <p class="text-center text-white mt-3 small opacity-75">&copy; <%= new Date().getFullYear() %> - Sistema de Gestión</p>
            </div>
        </div>
    </div>
</body>
</html>
