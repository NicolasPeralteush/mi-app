<%- include('partials/header', { titulo: 'Dashboard', usuario: usuario }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h5>
        <small class="text-muted">Resumen del día</small>
    </div>
    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
        <i class="bi bi-calendar3 me-1"></i><%= new Date().toLocaleDateString('es-ES', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
    </span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <small class="text-muted text-uppercase fw-semibold" style="font-size:10px;">Ventas Hoy</small>
                        <h4 class="fw-bold mb-0 text-success">$<%= parseFloat(ventasDia.total || 0).toFixed(2) %></h4>
                        <small class="text-muted"><%= ventasDia.cantidad || 0 %> ventas</small>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-3 p-2 align-self-start">
                        <i class="bi bi-cart-check text-success" style="font-size:1.3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <small class="text-muted text-uppercase fw-semibold" style="font-size:10px;">Productos Vend.</small>
                        <h4 class="fw-bold mb-0 text-info"><%= ventasDia.items || 0 %></h4>
                        <small class="text-muted">unidades hoy</small>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-3 p-2 align-self-start">
                        <i class="bi bi-boxes text-info" style="font-size:1.3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <small class="text-muted text-uppercase fw-semibold" style="font-size:10px;">Caja Actual</small>
                        <h4 class="fw-bold mb-0 <%= caja.abierta ? 'text-warning' : 'text-danger' %>">$<%= parseFloat(caja.saldo || 0).toFixed(2) %></h4>
                        <small class="text-muted"><%= caja.abierta ? 'Abierta' : 'Cerrada' %></small>
                    </div>
                    <div class="<%= caja.abierta ? 'bg-warning' : 'bg-danger' %> bg-opacity-10 rounded-3 p-2 align-self-start">
                        <i class="bi bi-cash-stack <%= caja.abierta ? 'text-warning' : 'text-danger' %>" style="font-size:1.3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <small class="text-muted text-uppercase fw-semibold" style="font-size:10px;">Stock Bajo</small>
                        <h4 class="fw-bold mb-0 text-danger"><%= bajoStock.length %></h4>
                        <small class="text-muted">productos críticos</small>
                    </div>
                    <div class="bg-danger bg-opacity-10 rounded-3 p-2 align-self-start">
                        <i class="bi bi-exclamation-triangle text-danger" style="font-size:1.3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white rounded-top-4 border-bottom-0 py-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-exclamation-diamond me-2 text-danger"></i>Stock Bajo</h6>
            </div>
            <div class="card-body p-0">
                <% if (bajoStock.length === 0) { %>
                    <div class="text-center text-muted py-4"><i class="bi bi-check-circle text-success fs-3 d-block mb-1"></i><small>No hay productos con stock bajo</small></div>
                <% } else { %>
                    <div class="list-group list-group-flush">
                        <% bajoStock.forEach(function(p) { %>
                            <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3">
                                <div>
                                    <span class="fw-medium small"><%= p.nombre %></span>
                                    <br><small class="text-muted">Stock: <strong class="<%= p.stock <= 0 ? 'text-danger' : 'text-warning' %>"><%= p.stock %></strong> / Mín: <%= p.stock_minimo %></small>
                                </div>
                                <a href="/kiosco/productos/<%= p.id %>/editar" class="btn btn-sm btn-outline-warning rounded-pill"><i class="bi bi-pencil"></i></a>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white rounded-top-4 border-bottom-0 py-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Últimas Ventas</h6>
            </div>
            <div class="card-body p-0">
                <% if (ultimasVentas.length === 0) { %>
                    <div class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-1"></i><small>Sin ventas registradas</small></div>
                <% } else { %>
                    <div class="list-group list-group-flush">
                        <% ultimasVentas.forEach(function(v) { %>
                            <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3">
                                <div>
                                    <span class="fw-medium small">#<%= v.id %></span>
                                    <br><small class="text-muted"><%= v.usuario_nombre %> - <%= new Date(v.fecha).toLocaleString('es-ES') %></small>
                                </div>
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill">$<%= parseFloat(v.total).toFixed(2) %></span>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
