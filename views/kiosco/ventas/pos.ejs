<%- include('../partials/header', { titulo: 'Punto de Venta', usuario: usuario, seccion: 'ventas' }) %>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-circle me-1"></i><%= error %></div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success py-2 small">
        <i class="bi bi-check-circle me-1"></i>Venta #<%= success.id %> registrada - Total: $<%= success.total %>
        <a href="/kiosco/ventas" class="btn btn-sm btn-success ms-2 rounded-pill"><i class="bi bi-plus"></i> Nueva venta</a>
    </div>
<% } %>

<div class="row g-3">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-search me-2"></i>Buscar Producto</div>
            <div class="card-body">
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="buscador" placeholder="Código o nombre..." autofocus>
                    <button class="btn btn-primary" type="button" id="btnBuscar"><i class="bi bi-search"></i></button>
                </div>
                <div id="resultadosBusqueda" class="list-group mb-3" style="max-height:300px;overflow-y:auto;"></div>
            </div>
        </div>
        <div class="card mt-3">
            <div class="card-header d-flex justify-content-between">
                <span><i class="bi bi-cart me-2"></i>Carrito</span>
                <span id="itemCount" class="badge bg-primary rounded-pill">0</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:35%">Producto</th>
                                <th class="text-center" style="width:15%">Cant</th>
                                <th class="text-end" style="width:20%">Precio</th>
                                <th class="text-end" style="width:20%">Subtotal</th>
                                <th style="width:10%"></th>
                            </tr>
                        </thead>
                        <tbody id="carritoBody"></tbody>
                    </table>
                </div>
                <% if (!success) { %>
                    <div class="p-3 border-top">
                        <div class="row g-2 align-items-center">
                            <div class="col-6">
                                <span class="text-muted small">Items: <strong id="totalItems">0</strong></span>
                            </div>
                            <div class="col-6 text-end">
                                <span class="h5 fw-bold">$<span id="totalCarrito">0.00</span></span>
                            </div>
                        </div>
                        <button class="btn btn-success w-100 mt-2" id="btnCobrar"><i class="bi bi-check2-circle me-1"></i>Cobrar</button>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card">
            <div class="card-header"><i class="bi bi-coin me-2"></i>Resumen</div>
            <div class="card-body">
                <div id="resumenCarrito">
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-cart-x fs-1 d-block mb-2"></i>
                        <small>Carrito vacío. Busque productos para agregar.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const carrito = [];
    const buscador = document.getElementById('buscador');
    const resultados = document.getElementById('resultadosBusqueda');
    const carritoBody = document.getElementById('carritoBody');
    const totalCarrito = document.getElementById('totalCarrito');
    const totalItems = document.getElementById('totalItems');
    const itemCount = document.getElementById('itemCount');
    const btnCobrar = document.getElementById('btnCobrar');

    let timeoutId = null;
    buscador.addEventListener('input', function() {
        clearTimeout(timeoutId);
        timeoutId = setTimeout(buscarProductos, 300);
    });

    document.getElementById('btnBuscar').addEventListener('click', buscarProductos);

    async function buscarProductos() {
        const q = buscador.value.trim();
        if (!q) { resultados.innerHTML = ''; return; }
        try {
            const res = await fetch('/kiosco/ventas/buscar?q=' + encodeURIComponent(q));
            const data = await res.json();
            if (data.length === 0) {
                resultados.innerHTML = '<div class="list-group-item text-muted small">Sin resultados</div>';
                return;
            }
            resultados.innerHTML = data.map(p => `
                <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2"
                    data-id="${p.id}" data-nombre="${p.nombre}" data-precio="${p.precio_venta}" data-stock="${p.stock}">
                    <div>
                        <strong class="small">${p.nombre}</strong>
                        <br><small class="text-muted">Cód: ${p.codigo} | Stock: ${p.stock}</small>
                    </div>
                    <span class="fw-bold text-primary">$${parseFloat(p.precio_venta).toFixed(2)}</span>
                </button>
            `).join('');
            resultados.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', function() {
                    const id = parseInt(this.dataset.id);
                    const nombre = this.dataset.nombre;
                    const precio = parseFloat(this.dataset.precio);
                    const stock = parseFloat(this.dataset.stock);
                    agregarAlCarrito(id, nombre, precio, stock);
                    buscador.value = '';
                    resultados.innerHTML = '';
                    buscador.focus();
                });
            });
        } catch(e) { console.error(e); }
    }

    function agregarAlCarrito(id, nombre, precio, stock) {
        const existente = carrito.find(item => item.id === id);
        if (existente) {
            if (existente.cantidad >= stock) { alert('Stock máximo alcanzado'); return; }
            existente.cantidad++;
        } else {
            carrito.push({ id, nombre, precio, cantidad: 1, stock });
        }
        renderCarrito();
    }

    function renderCarrito() {
        if (carrito.length === 0) {
            carritoBody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4"><small>Carrito vacío</small></td></tr>';
            document.getElementById('resumenCarrito').innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-cart-x fs-1 d-block mb-2"></i><small>Carrito vacío</small></div>';
            totalCarrito.textContent = '0.00';
            totalItems.textContent = '0';
            itemCount.textContent = '0';
            return;
        }
        let total = 0;
        let items = 0;
        let html = '';
        carrito.forEach((item, i) => {
            const subtotal = item.cantidad * item.precio;
            total += subtotal;
            items += item.cantidad;
            html += `<tr>
                <td><small class="fw-medium">${item.nombre}</small></td>
                <td class="text-center">
                    <div class="input-group input-group-sm">
                        <button class="btn btn-outline-secondary btn-xs" onclick="window.cambiarCant(${i}, -1)">-</button>
                        <input type="number" class="form-control form-control-sm text-center" value="${item.cantidad}" min="1" max="${item.stock}" style="width:45px" onchange="window.cambiarCantInput(${i}, this.value)">
                        <button class="btn btn-outline-secondary btn-xs" onclick="window.cambiarCant(${i}, 1)">+</button>
                    </div>
                </td>
                <td class="text-end small">$${item.precio.toFixed(2)}</td>
                <td class="text-end fw-bold">$${subtotal.toFixed(2)}</td>
                <td class="text-center"><button class="btn btn-outline-danger btn-sm py-0" onclick="window.eliminarItem(${i})"><i class="bi bi-trash"></i></button></td>
            </tr>`;
        });
        carritoBody.innerHTML = html;
        totalCarrito.textContent = total.toFixed(2);
        totalItems.textContent = items;
        itemCount.textContent = items;

        document.getElementById('resumenCarrito').innerHTML = `
            <table class="table table-sm mb-0">
                <tr><td>Items</td><td class="text-end"><strong>${items}</strong></td></tr>
                <tr><td>Total</td><td class="text-end"><h5 class="fw-bold mb-0">$${total.toFixed(2)}</h5></td></tr>
            </table>
        `;
    }

    window.cambiarCant = function(i, delta) {
        const item = carrito[i];
        const nueva = item.cantidad + delta;
        if (nueva < 1 || nueva > item.stock) return;
        item.cantidad = nueva;
        renderCarrito();
    };

    window.cambiarCantInput = function(i, val) {
        const nueva = parseInt(val);
        if (isNaN(nueva) || nueva < 1) { renderCarrito(); return; }
        const item = carrito[i];
        if (nueva > item.stock) { alert('Stock máximo: ' + item.stock); renderCarrito(); return; }
        item.cantidad = nueva;
        renderCarrito();
    };

    window.eliminarItem = function(i) {
        carrito.splice(i, 1);
        renderCarrito();
    };

    if (btnCobrar) {
        btnCobrar.addEventListener('click', async function() {
            if (carrito.length === 0) { alert('Carrito vacío'); return; }
            if (!confirm('¿Confirmar venta por $' + totalCarrito.textContent + '?')) return;
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Procesando...';
            try {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/kiosco/ventas';
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'items';
                input.value = JSON.stringify(carrito.map(i => ({ id: i.id, cantidad: i.cantidad, precio: i.precio })));
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            } catch(e) {
                alert('Error al procesar venta');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>Cobrar';
            }
        });
    }
})();
</script>

<%- include('../partials/footer') %>
