# ============================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================
PORT=3000
SESSION_SECRET=poner-aqui-una-clave-secreta-segura

# ============================================================
# BASE DE DATOS MYSQL - MÓDULO KIOSCO
# ============================================================
# Usar el prefijo K_ para configuración específica del kiosco,
# o DB_ para compartir con otros módulos
K_DB_HOST=localhost
K_DB_USER=root
K_DB_PASS=
K_DB_NAME=kiosco
K_DB_PORT=3306

# Alternativa sin prefijo (compartida)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=kiosco
# DB_PORT=3306
